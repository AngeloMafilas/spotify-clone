# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/spotify_db?appName=Cluster0

# Clerk Authentication (https://clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Cloudinary (for image/audio storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# === AI Services ===

# Grok (xAI) API (for AI playlists, lyrics analysis, DJ scripts)
# Get key: https://x.ai/api
GROK_API_KEY=your_xai_api_key_here
GROK_BASE_URL=https://api.x.ai/v1

# Session secret for cookies (generate random string)
SESSION_SECRET=your_random_secret_key_at_least_32_chars
